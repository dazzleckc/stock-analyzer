!         existing = pl.read_parquet(existing_path, columns=["trade_date"])
!         existing_dates = set(existing["trade_date"].to_list())
>     else:
>         existing_dates = set()
  
>     missing = [d for d in trading_days if d not in existing_dates]
>     return missing
  
  
  # ═══════════════════════════════════════════════════════════════════
  # 全量重算
  # ═══════════════════════════════════════════════════════════════════
  
> def calc_full() -> dict:
>     """全量重算：遍历交易日历 → 逐日计算 → 原子覆盖写入。
  
>     返回: {"dates": int, "rows": int}
>     """
>     print("全量计算市场指标...")
  
      # 读 kline（只读需要的列）
>     print(f"  读 kline_daily.parquet ...")
>     kline = pl.read_parquet(KLINE_PATH, columns=[
>         "code", "trade_date", "high", "low", "amount", "pct_change",
>     ])
>     kline_min = kline["trade_date"].min()
>     kline_max = kline["trade_date"].max()
>     print(f"  kline 日期范围：{kline_min} ~ {kline_max}")
  
      # 读交易日历，限缩到 kline 覆盖的范围
>     cal = pl.read_parquet(TRADE_CAL_PATH)
>     trading_days = (
>         cal.filter(pl.col("is_open") == 1)
>         .filter(pl.col("cal_date").is_between(kline_min, kline_max))
>         .sort("cal_date")["cal_date"]
>         .to_list()
>     )
>     print(f"  交易日历（限缩）：{len(trading_days)} 个交易日")
  
      # 读 ST 数据
>     st = pl.read_parquet(ST_STOCK_PATH, columns=["code", "trade_date"])
  
      # 读退市整理期数据
>     delist = pl.read_parquet(DELIST_PATH, columns=["code", "imp_date"])
  
      # 预计算 rolling
>     print(f"  预计算 rolling 指标...")
>     kline_with_rolling = _precompute_rolling(kline)
  
      # 构建日期索引映射
>     date_index_map = {d: i for i, d in enumerate(trading_days)}
  
      # 逐日计算
>     records: list[dict] = []
>     total = len(trading_days)
>     for i, d in enumerate(trading_days):
>         if (i + 1) % 20 == 0 or i == 0:
>             print(f"  进度: {i + 1}/{total}（已产出 {len(records)} 行）")
>         result = calc_single_day(d, kline, st, delist, kline_with_rolling, date_index_map)
>         if result is not None:
>             records.append(result)
  
>     if not records:
!         print("  无有效交易日数据")
!         empty_df = pl.DataFrame(schema=INDICATORS_SCHEMA)
!         atomic_write_parquet(empty_df, INDICATORS_PATH)
!         return {"dates": 0, "rows": 0}
  
>     df = pl.DataFrame(records, schema=INDICATORS_SCHEMA, orient="row")
>     atomic_write_parquet(df, INDICATORS_PATH)
  
>     print(f"  → {len(df)} 行（{df['trade_date'].n_unique()} 个交易日）已保存到 {INDICATORS_PATH}")
  
>     return {"dates": df["trade_date"].n_unique(), "rows": len(df)}
  
  
