>     missing_dates = [d for d in all_trading_days if d not in existing_dates]
>     if not missing_dates:
!         print("无需更新")
!         return {"dates": 0, "rows": len(existing), "new_dates": 0}
  
      # 读 ST 数据
>     st = pl.read_parquet(ST_STOCK_PATH, columns=["code", "trade_date"])
  
      # 读退市整理期数据
>     delist = pl.read_parquet(DELIST_PATH, columns=["code", "imp_date"])
  
      # 预计算 rolling（全量 kline，因为 rolling 依赖历史数据）
>     kline_with_rolling = _precompute_rolling(kline)
  
      # 构建日期索引映射
>     date_index_map = {d: i for i, d in enumerate(all_trading_days)}
  
      # 逐日计算缺失日
