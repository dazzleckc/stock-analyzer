  # 缺失日期发现（增量模式）
  # ═══════════════════════════════════════════════════════════════════
  
> def _find_missing_dates(trade_cal_path: str, existing_path: str) -> list[datetime.date]:
>     """发现缺失的交易日列表（用于增量模式）。
  
>     比较 trade_cal 中所有交易日与已存在的 indicators 日期，
>     返回缺失日期列表（已排序）。
>     """
>     cal = pl.read_parquet(trade_cal_path)
>     trading_days = (
>         cal.filter(pl.col("is_open") == 1)
>         .sort("cal_date")["cal_date"]
>         .to_list()
