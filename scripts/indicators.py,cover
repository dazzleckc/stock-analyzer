>         if result is not None:
>             records.append(result)
  
>     if not records:
!         print("  缺失日无有效数据")
!         return {"dates": len(existing), "rows": len(existing), "new_dates": 0}
  
>     new_df = pl.DataFrame(records, schema=INDICATORS_SCHEMA, orient="row")
  
      # 合并：旧 + 新 → sort
>     old_df = pl.read_parquet(INDICATORS_PATH)
>     merged = pl.concat([old_df, new_df], how="vertical").sort("trade_date")
  
>     atomic_write_parquet(merged, INDICATORS_PATH)
  
>     print(f"  → 新增 {len(new_df)} 行，合计 {len(merged)} 行，"
>           f"已保存到 {INDICATORS_PATH}")
  
>     return {
>         "dates": merged["trade_date"].n_unique(),
>         "rows": len(merged),
