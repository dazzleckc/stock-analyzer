> """市场指标日频计算脚本。
  
> 计算以下 5 个日频市场指标，写入 indicators.parquet：
>   - top20_amount_ratio    TOP20 成交额占比
>   - up_ge7_count          涨跌幅 >= 7% 的股票数
>   - down_le7_count        涨跌幅 <= -7% 的股票数
>   - net_high_20d          20 日净新高（新高 - 新低）
>   - net_high_60d          60 日净新高（新高 - 新低）
  
> 使用方式：
>   python scripts/indicators.py              # 增量（缺哪日算哪日）
>   python scripts/indicators.py --full        # 全量重算
> """
  
> import argparse
> import datetime
> import os
> import sys
  
> import polars as pl
  
> sys.path.insert(0, os.path.dirname(os.path.dirname(__file__)))
> from config import (                              # noqa: E402
>     TRADE_CAL_PATH, KLINE_PATH, ST_STOCK_PATH, DELIST_PATH,
>     INDICATORS_PATH, INDICATORS_SCHEMA,
>     atomic_write_parquet,
> )
  
  
  # ═══════════════════════════════════════════════════════════════════
  # Rolling 预计算
  # ═══════════════════════════════════════════════════════════════════
  
> def _precompute_rolling(kline: pl.DataFrame) -> pl.DataFrame:
>     """预计算每只股票的 rolling_max(high) 和 rolling_min(low)，20d+60d。
  
>     步骤：
>     1. kline 按 code, trade_date 排序
>     2. 对每只股票计算 rolling 列
>     3. 返回附加了 rolling 列的 DataFrame
>     """
>     kline = kline.sort(["code", "trade_date"])
>     kline = kline.with_columns([
>         pl.col("high").rolling_max(window_size=20, min_samples=1).over("code").alias("rolling_high_20d"),
>         pl.col("high").rolling_max(window_size=60, min_samples=1).over("code").alias("rolling_high_60d"),
>         pl.col("low").rolling_min(window_size=20, min_samples=1).over("code").alias("rolling_low_20d"),
>         pl.col("low").rolling_min(window_size=60, min_samples=1).over("code").alias("rolling_low_60d"),
>     ])
>     return kline
  
  
  # ═══════════════════════════════════════════════════════════════════
  # 单日指标计算
  # ═══════════════════════════════════════════════════════════════════
  
> def calc_single_day(
>     d: datetime.date,
>     kline_all: pl.DataFrame,
>     st_all: pl.DataFrame,
>     delist_all: pl.DataFrame,
>     kline_with_rolling: pl.DataFrame,
>     trade_date_index_map: dict,
> ) -> dict | None:
>     """计算单个交易日所有指标。
  
>     8 步计算流程：
>     1. 取当日 kline 数据
>     2. 获取当日 ST 代码
>     3. 获取退市整理期代码（imp_date <= d）
>     4. 合并排除列表
>     5. 过滤排除代码
>     6. TOP20 成交额占比
>     7. 涨跌幅计数（>=7% / <=-7%）
>     8. 净新高计数（使用预计算 rolling 值）
>     """
      # 1. 取当日数据（用 kline_with_rolling，含 rolling 列）
>     kline_today = kline_with_rolling.filter(pl.col("trade_date") == d)
>     if kline_today.is_empty():
>         return None
  
      # 2. 当日 ST 代码
>     st_codes_today = st_all.filter(pl.col("trade_date") == d)["code"].unique()
  
      # 3. 退市整理期代码
>     delist_codes = delist_all.filter(pl.col("imp_date") <= d)["code"].unique()
  
      # 4. 合并排除列表
>     exclude = list(set(st_codes_today.to_list()) | set(delist_codes.to_list()))
  
      # 5. 过滤
>     filtered = kline_today.filter(~pl.col("code").is_in(exclude))
>     if filtered.is_empty():
>         return None
  
      # 6. TOP20 成交额占比
>     total = filtered["amount"].sum()
>     if total > 0:
>         top20 = filtered.sort("amount", descending=True).head(20)["amount"].sum()
>         ratio = top20 / total * 100
!     else:
!         ratio = 0.0
  
      # 7. 涨跌幅计数
>     up = filtered.filter(pl.col("pct_change") >= 7.0).height
>     down = filtered.filter(pl.col("pct_change") <= -7.0).height
  
      # 8. 净新高
>     idx = trade_date_index_map[d]
  
>     if idx >= 19:
>         high_20 = filtered.filter(pl.col("high") >= pl.col("rolling_high_20d")).height
>         low_20 = filtered.filter(pl.col("low") <= pl.col("rolling_low_20d")).height
>         net_20 = high_20 - low_20
>     else:
>         net_20 = None
  
>     if idx >= 59:
>         high_60 = filtered.filter(pl.col("high") >= pl.col("rolling_high_60d")).height
>         low_60 = filtered.filter(pl.col("low") <= pl.col("rolling_low_60d")).height
>         net_60 = high_60 - low_60
>     else:
>         net_60 = None
  
>     return {
>         "trade_date": d,
>         "top20_amount_ratio": ratio,
>         "up_ge7_count": up,
>         "down_le7_count": down,
>         "net_high_20d": net_20,
>         "net_high_60d": net_60,
>     }
  
  
