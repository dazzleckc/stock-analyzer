  # 增量计算
  # ═══════════════════════════════════════════════════════════════════
  
> def calc_incremental() -> dict:
>     """增量计算：读已有 → 找缺失日 → 只算新日 → 合并写入。
  
>     返回: {"dates": int, "rows": int, "new_dates": int}
>     """
>     if not os.path.exists(INDICATORS_PATH):
!         print("⚠ 无本地 indicators.parquet，切换为全量模式")
